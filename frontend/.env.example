# Backend API URL - defaults to http://localhost:3001 if not set
# For local development:
REACT_APP_API_URL=http://localhost:3001

# API Key for authentication (leave empty for development without auth)
# Generate a secure key: openssl rand -hex 32
REACT_APP_API_KEY=

# For production (set in GitHub Secrets):
# REACT_APP_API_URL=https://thor-api.devshram.in
# REACT_APP_API_KEY=your-secure-api-key

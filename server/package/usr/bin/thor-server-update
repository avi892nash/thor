#!/bin/bash
# Thor Server - Auto-updater
# Compares the locally-installed release tag against /releases/latest on GitHub
# and applies the new .deb if they differ. Runs as root via systemd oneshot.

set -e

REPO="avi892nash/thor"
INSTALLED_TAG_FILE="/var/lib/thor-server/installed-tag"

# Print to stdout; systemd's SyslogIdentifier=thor-update routes it to journald
# under the same tag the timer-driven runs use, so `journalctl -t thor-update`
# still works. Errors go to stderr.
log()  { printf '[thor-update] %s\n' "$*"; }
fail() { printf '[thor-update] ERROR: %s\n' "$*" >&2; exit 1; }

# Check dpkg lock — if another apt/dpkg process is running, skip and retry next poll
if lsof /var/lib/dpkg/lock-frontend &>/dev/null 2>&1; then
  log "dpkg locked by another process, skipping (will retry next poll)"
  exit 0
fi

# Fetch release metadata from GitHub API
API_URL="https://api.github.com/repos/${REPO}/releases/latest"

HTTP_CODE=$(curl -o /dev/null -sw "%{http_code}" \
  -H "Accept: application/vnd.github+json" \
  "$API_URL" 2>/dev/null)

if [ "$HTTP_CODE" = "404" ]; then
  log "No release found yet, skipping"
  exit 0
fi

if [ "$HTTP_CODE" != "200" ]; then
  log "GitHub API returned HTTP $HTTP_CODE, skipping"
  exit 0
fi

RELEASE_JSON=$(curl -fsSL \
  -H "Accept: application/vnd.github+json" \
  "$API_URL" 2>/dev/null) || { log "GitHub API unreachable, skipping"; exit 0; }

# Helper: parse JSON via node (always present — package depends on nodejs)
json_get() {
  # usage: echo "$JSON" | json_get '<node expression returning a string>'
  node -e "
    let s='';process.stdin.on('data',d=>s+=d).on('end',()=>{
      const d = JSON.parse(s);
      const out = ($1);
      if (out !== undefined && out !== null) process.stdout.write(String(out));
    });
  "
}

# Extract tag and asset URL from /releases/latest
TAG=$(echo "$RELEASE_JSON" | json_get "d.tag_name")
DOWNLOAD_URL=$(echo "$RELEASE_JSON" | json_get "(d.assets||[]).find(a=>a.name==='thor-api.deb')?.browser_download_url")

[ -n "$TAG" ] || fail "release has no tag_name"
[ -n "$DOWNLOAD_URL" ] || fail "no thor-api.deb asset on release $TAG"

# Compare with locally installed tag (written here after the previous update)
LOCAL_TAG=$(cat "$INSTALLED_TAG_FILE" 2>/dev/null || echo "")

if [ "$LOCAL_TAG" = "$TAG" ]; then
  log "Up to date ($TAG)"
  exit 0
fi

log "Update available: ${LOCAL_TAG:-none} → $TAG"

# Download to temp file (cleaned up on exit)
TMPFILE=$(mktemp /tmp/thor-server-XXXXXX.deb)
trap 'rm -f "$TMPFILE"' EXIT

log "Downloading $DOWNLOAD_URL"
curl -fsSL "$DOWNLOAD_URL" -o "$TMPFILE" || fail "download failed"

# Install the new package
log "Installing $TAG..."
apt install -y "$TMPFILE" || fail "apt install failed (see apt output above)"

# Persist the installed tag for the next run's comparison
mkdir -p "$(dirname "$INSTALLED_TAG_FILE")"
echo "$TAG" > "$INSTALLED_TAG_FILE"

log "Successfully updated to $TAG"

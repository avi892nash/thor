#!/bin/bash
# Thor Server - Auto-updater
# Checks GitHub Releases for a new build; downloads and installs if SHA differs.
# Runs as root via systemd oneshot service.

set -e

REPO="avi892nash/thor"
RELEASE_TAG="latest"
VERSION_FILE="/usr/lib/thor-server/dist/.version"
LOG_TAG="thor-update"

log()  { logger -t "$LOG_TAG" "$1"; }
fail() { logger -t "$LOG_TAG" "ERROR: $1"; exit 1; }

# Check dpkg lock — if another apt/dpkg process is running, skip and retry next poll
if lsof /var/lib/dpkg/lock-frontend &>/dev/null 2>&1; then
  log "dpkg locked by another process, skipping (will retry next poll)"
  exit 0
fi

# Fetch release metadata from GitHub API
API_URL="https://api.github.com/repos/${REPO}/releases/tags/${RELEASE_TAG}"

HTTP_CODE=$(curl -o /dev/null -sw "%{http_code}" \
  -H "Accept: application/vnd.github+json" \
  "$API_URL" 2>/dev/null)

if [ "$HTTP_CODE" = "404" ]; then
  log "No release found yet (server-latest tag missing), skipping"
  exit 0
fi

if [ "$HTTP_CODE" != "200" ]; then
  log "GitHub API returned HTTP $HTTP_CODE, skipping"
  exit 0
fi

RELEASE_JSON=$(curl -fsSL \
  -H "Accept: application/vnd.github+json" \
  "$API_URL" 2>/dev/null) || { log "GitHub API unreachable, skipping"; exit 0; }

# Extract commit SHA from release body (format: "sha:<40-char-hex>")
REMOTE_SHA=$(python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
for token in d.get('body', '').split():
    if token.startswith('sha:'):
        print(token[4:])
        break
" <<< "$RELEASE_JSON")

[ -n "$REMOTE_SHA" ] || { log "Could not parse SHA from release body, skipping"; exit 0; }

# Compare with locally installed version
LOCAL_SHA=$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || echo "none")

if [ "$LOCAL_SHA" = "$REMOTE_SHA" ]; then
  log "Up to date ($LOCAL_SHA)"
  exit 0
fi

log "Update available: $LOCAL_SHA → $REMOTE_SHA"

# Get download URL for thor-api.deb asset
DOWNLOAD_URL=$(python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
for a in d.get('assets', []):
    if a['name'] == 'thor-api.deb':
        print(a['browser_download_url'])
        break
" <<< "$RELEASE_JSON")

[ -n "$DOWNLOAD_URL" ] || fail "No thor-api.deb asset found in release"

# Download to temp file (cleaned up on exit)
TMPFILE=$(mktemp /tmp/thor-server-XXXXXX.deb)
trap 'rm -f "$TMPFILE"' EXIT

log "Downloading from $DOWNLOAD_URL..."
curl -fsSL "$DOWNLOAD_URL" -o "$TMPFILE" || fail "Download failed"

# Verify SHA256 if embedded in release notes (format: "deb_sha256:<hash>")
EXPECTED_SHA256=$(python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
for token in d.get('body', '').split():
    if token.startswith('deb_sha256:'):
        print(token[11:])
        break
" <<< "$RELEASE_JSON")

if [ -n "$EXPECTED_SHA256" ]; then
  ACTUAL_SHA256=$(sha256sum "$TMPFILE" | cut -d' ' -f1)
  if [ "$ACTUAL_SHA256" != "$EXPECTED_SHA256" ]; then
    fail "SHA256 mismatch — download may be corrupt, aborting"
  fi
  log "SHA256 verified"
fi

# Install the new package
log "Installing new package..."
apt install -y "$TMPFILE" && log "Successfully updated to $REMOTE_SHA"

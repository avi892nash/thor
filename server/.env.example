# Thor Server Environment Configuration

# Server port
PORT=3001

# API Key for authentication
# Generate a secure key: openssl rand -hex 32
# Leave empty to disable authentication (development only!)
THOR_API_KEY=

# Allowed origins for CORS (comma-separated)
# Example: https://thor.devshram.in,https://www.thor.devshram.in
ALLOWED_ORIGINS=http://localhost:3000

# Node environment
NODE_ENV=development

# Base URL where versioned frontend builds are hosted (no trailing slash)
# Used by GET /frontend to return the correct versioned URL to the loader
FRONTEND_BASE_URL=https://devshram.com/projects/thor
